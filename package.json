{
    "name": "one-moment",
    "version": "0.1.0",
    "description": "A fast Windows launcher with app search, clipboard history, commands, and web shortcuts.",
    "author": "Nicholas Falcone",
    "homepage": "https://github.com/NicholasFalcone/momentum",
    "repository": {
        "type": "git",
        "url": "https://github.com/NicholasFalcone/momentum.git"
    },
    "main": "main.js",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "electron": "electron .",
        "start": "concurrently \"npm run dev\" \"npm run electron\"",
        "dist": "npm run build && electron-builder --win nsis --x64",
        "dist:x64": "npm run build && electron-builder --win nsis --x64",
        "sign:installer": "powershell -ExecutionPolicy Bypass -File .\\scripts\\sign-installer.ps1"
    },
    "build": {
        "appId": "com.onemoment.launcher",
        "productName": "One Moment",
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*",
            "main.js",
            "preload.js",
            "search_engine.js",
            "clipboard_service.js",
            "settings_manager.js",
            "assets/**/*",
            "package.json"
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "assets/icon.png"
        },
        "nsis": {
            "oneClick": true,
            "perMachine": false,
            "allowElevation": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "One Moment",
            "uninstallDisplayName": "One Moment"
        }
    },
    "dependencies": {
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "framer-motion": "^10.12.16",
        "lucide-react": "^0.244.0"
    },
    "devDependencies": {
        "@types/minimatch": "^5.1.2",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@vitejs/plugin-react": "^1.3.0",
        "concurrently": "^7.6.0",
        "electron": "^22.0.0",
        "electron-builder": "^22.14.13",
        "typescript": "^4.9.5",
        "vite": "^2.9.0"
    }
}